# Extended Exchange — authentication
# All five values are generated together when creating API keys in the Extended Exchange UI.
# NOTE: EXTENDED_PRIVATE_KEY and EXTENDED_PUBLIC_KEY are passed to the SDK but
# are never used for signing — this is a read-only monitoring system.
EXTENDED_API_KEY=sk-your-api-key
EXTENDED_PUBLIC_KEY=0x...your-stark-public-key
EXTENDED_PRIVATE_KEY=0x...your-stark-private-key
EXTENDED_VAULT=your-vault-number
EXTENDED_CLIENT_ID=your-client-id
EXTENDED_NETWORK=mainnet

# Telegram
TELEGRAM_BOT_TOKEN=0000000000:your-bot-token
TELEGRAM_CHAT_ID=-100your-chat-id

# Polling intervals (seconds)
POLL_INTERVAL_ORDERS_SECONDS=60
POLL_INTERVAL_POSITIONS_SECONDS=60
POLL_INTERVAL_HISTORY_SECONDS=60

# Persistence
STATE_DB_PATH=/data/state.db
NOTIFICATION_DEDUP_TTL_DAYS=30

# Notifications — set to false to disable individual event types
ENABLE_ORDER_OPENED=true
ENABLE_ORDER_UPDATED=true
ENABLE_ORDER_FILLED=true
ENABLE_POSITION_OPENED=true
ENABLE_POSITION_UPDATED=true
ENABLE_POSITION_CLOSED=true
ENABLE_STARTUP_NOTIFICATION=true

# Unrealized PnL alert threshold in USDC (optional — leave empty to disable)
UNREALIZED_PNL_THRESHOLD_USDC=

# Logging — json (default, recommended for Docker) or text (for local dev)
LOG_LEVEL=INFO
LOG_FORMAT=json
